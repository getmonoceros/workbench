{
  "name": "@getmonoceros/workbench",
  "version": "1.12.0",
  "description": "Monoceros workbench CLI — local, reproducible dev containers with first-class AI coding tooling.",
  "keywords": [
    "devcontainer",
    "docker",
    "cli",
    "ai-coding",
    "claude-code",
    "monoceros"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getmonoceros/workbench.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/getmonoceros/workbench#readme",
  "bugs": {
    "url": "https://github.com/getmonoceros/workbench/issues"
  },
  "type": "module",
  "bin": {
    "monoceros": "./dist/bin.js"
  },
  "files": [
    "dist",
    "templates",
    "features",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/bin.ts",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "manifests:sync": "node scripts/sync-feature-manifests.mjs",
    "prebuild": "pnpm manifests:sync",
    "build": "tsup",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@devcontainers/cli": "^0.86.1",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "diff": "^9.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
