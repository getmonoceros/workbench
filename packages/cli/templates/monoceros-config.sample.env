# Global settings shared across all your Monoceros containers - optional
# defaults and credentials, so you don't repeat them in every container's
# container-configs/<name>.env (which overrides anything set here).
# Monoceros runs fine without this file. Never commit real tokens.

# Git: GitHub and GitLab repositories, plus the gh and glab CLIs
# https://getmonoceros.build/docs/concepts/git-and-repos/
# GITHUB_API_TOKEN=
# GITLAB_API_TOKEN=
# GIT_TOKEN__GITHUB_ACME=
# GIT_TOKEN__GITLAB_MYGROUP=

# Atlassian: Rovo Dev, twg, and Forge, plus Bitbucket
# https://getmonoceros.build/docs/features/atlassian/
# ATLASSIAN_EMAIL=
# ATLASSIAN_INSTANCE=yoursite.atlassian.net
# ATLASSIAN_API_TOKEN=
# ATLASSIAN_BITBUCKET_TOKEN=
