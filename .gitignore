# macOS
.DS_Store
.AppleDouble
.LSOverride

# Node
node_modules/
dist/
build/
out/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Env
.env
.env.local
.env.*.local

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# pnpm
.pnpm-store/

# TypeScript
*.tsbuildinfo

# Generated by `pnpm components:sync` (see
# packages/cli/scripts/sync-components.mjs). Source of truth is the
# checkout-root components/ tree; this package-local copy is published
# with the npm tarball so the CLI's catalog works after a global install.
packages/cli/bundled-components/

# Generated by `pnpm manifests:generate` from each component.yml descriptor
# (ADR 0020). Materialized only for the GHCR feature publish; the CLI itself
# derives manifest data from the descriptor at runtime, so these are never
# committed.
components/features/*/devcontainer-feature.json

# Local scratch space — during development this folder doubles as the
# dev-time MONOCEROS_HOME (container-configs/, container/, the user's
# monoceros-config.yml). Almost everything in here is ephemeral and
# gitignored, EXCEPT the README + sample-config that mark the folder
# as the workbench-internal home.
.local/*
!.local/README.md
!.local/monoceros-config.sample.yml

# Private notes — strategic / monetization ideas, competitor research,
# pre-1.0 thinking that doesn't belong in the public docs/ tree.
# Anything under here is owner-only and stays out of the OSS repo.
docs/private/

# Built skill bundle - produced by `pnpm skill:zip` from skills/<name>/ and
# copied by hand into monoceros-web/public/. The source is committed; the zip
# is a throwaway build artifact, not version-controlled.
skills/*.zip

# Machine-local Claude Code files — owner-only, never in the OSS repo:
# the auto-loaded local memory pointer (points at sibling repos checked
# out only on this machine), the preview-tool launch shim, and personal
# permission settings.
.claude/CLAUDE.md
.claude/launch.json
.claude/settings.local.json
