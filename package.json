{
  "name": "monoceros-workbench",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.0.6",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "cli": "pnpm --filter @getmonoceros/workbench start",
    "image:build": "docker build -t monoceros-runtime:dev images/runtime",
    "image:rebuild": "docker build --no-cache -t monoceros-runtime:dev images/runtime",
    "sandbox:reset": "bash scripts/sandbox-reset.sh",
    "skill:zip": "rm -f skills/monoceros-guide.zip && (cd skills && zip -rX monoceros-guide.zip monoceros-guide -x '*.DS_Store')"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ]
  }
}
